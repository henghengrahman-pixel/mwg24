<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>

<body class="admin-page">
  <div class="admin-layout">

    <%- include("partials/admin-sidebar") %>

    <main class="admin-main">

      <div class="admin-head">
        <h1><%= item ? "Edit Berita" : "Tambah Berita" %></h1>
      </div>

      <form action="/admin/berita/save" method="post" enctype="multipart/form-data" class="admin-form">

        <input type="hidden" name="id" value="<%= item?.id || '' %>">
        <input type="hidden" name="current_image" value="<%= item?.image || '' %>">

        <!-- Judul -->
        <label>Judul Berita</label>
        <input
          type="text"
          name="title"
          placeholder="Contoh: Tempat Wisata Berastagi yang Wajib Dikunjungi"
          value="<%= item?.title || '' %>"
          required
        />

        <!-- Slug -->
        <label>Slug (URL)</label>
        <input
          type="text"
          name="slug"
          placeholder="otomatis jika kosong"
          value="<%= item?.slug || '' %>"
        />
        <small class="form-hint">
          URL akan menjadi: /berita/slug-anda
        </small>

        <!-- Kategori -->
        <label>Kategori</label>
        <select name="category">
          <option value="berita" <%= item?.category === "berita" ? "selected" : "" %>>Berita</option>
          <option value="wisata" <%= item?.category === "wisata" ? "selected" : "" %>>Wisata</option>
          <option value="kuliner" <%= item?.category === "kuliner" ? "selected" : "" %>>Kuliner</option>
          <option value="tips" <%= item?.category === "tips" ? "selected" : "" %>>Tips Liburan</option>
        </select>

        <!-- Excerpt -->
        <label>Ringkasan Artikel (Excerpt)</label>
        <textarea
          name="excerpt"
          rows="3"
          placeholder="Ringkasan singkat berita (untuk preview di homepage)"
        ><%= item?.excerpt || '' %></textarea>

        <!-- Konten -->
        <label>Konten Berita</label>
        <textarea
          name="content"
          rows="12"
          placeholder="Tulis isi berita lengkap di sini..."
          required
        ><%= item?.content || '' %></textarea>

        <!-- Upload gambar -->
        <label>Gambar Utama</label>

        <% if(item?.image){ %>
          <div class="image-preview">
            <img src="<%= item.image %>" alt="Preview">
          </div>
        <% } %>

        <input type="file" name="image" accept="image/*">

        <small class="form-hint">
          Upload gambar baru jika ingin mengganti gambar lama.
        </small>

        <!-- SEO -->
        <div class="form-divider">Pengaturan SEO</div>

        <label>Meta Title</label>
        <input
          type="text"
          name="meta_title"
          placeholder="Judul SEO (jika kosong otomatis)"
          value="<%= item?.meta_title || '' %>"
        />

        <label>Meta Description</label>
        <textarea
          name="meta_description"
          rows="3"
          placeholder="Deskripsi untuk Google"
        ><%= item?.meta_description || '' %></textarea>

        <!-- Button -->
        <div class="form-actions">

          <button type="submit" class="btn-primary">
            Simpan Berita
          </button>

          <a href="/admin/berita" class="btn-secondary">
            Batal
          </a>

        </div>

      </form>

    </main>
  </div>
</body>
</html>
