<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>
<body class="admin-page">
  <div class="admin-layout">
    <%- include("partials/admin-sidebar") %>
    <main class="admin-main">
      <div class="admin-head">
        <h1>Kelola Wisata</h1>
        <a href="/admin/wisata/new" class="btn-primary">Tambah Wisata</a>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Judul</th>
              <th>Lokasi</th>
              <th>Unggulan</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% items.forEach(item => { %>
              <tr>
                <td><%= item.title %></td>
                <td><%= item.location %></td>
                <td><%= item.is_featured ? 'Ya' : 'Tidak' %></td>
                <td class="actions">
                  <a href="/admin/wisata/edit/<%= item.id %>">Edit</a>
                  <form action="/admin/wisata/delete/<%= item.id %>" method="post" onsubmit="return confirm('Hapus data ini?')">
                    <button type="submit">Hapus</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
  </div>
</body>
</html>
