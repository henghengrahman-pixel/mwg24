<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>
<body class="admin-page">
  <div class="admin-layout">
    <%- include("partials/admin-sidebar") %>
    <main class="admin-main">
      <h1>Pengaturan Website</h1>

      <form action="/admin/settings" method="post" class="admin-form">
        <label>Nama Website</label>
        <input type="text" name="site_name" value="<%= settings.site_name %>" />

        <label>Tagline</label>
        <input type="text" name="site_tagline" value="<%= settings.site_tagline %>" />

        <label>Nomor HP / WA</label>
        <input type="text" name="contact_phone" value="<%= settings.contact_phone %>" />

        <label>Email</label>
        <input type="email" name="contact_email" value="<%= settings.contact_email %>" />

        <label>Alamat</label>
        <textarea name="address" rows="3"><%= settings.address %></textarea>

        <label>Footer Text</label>
        <textarea name="footer_text" rows="3"><%= settings.footer_text %></textarea>

        <label>Homepage Title</label>
        <input type="text" name="homepage_title" value="<%= settings.homepage_title %>" />

        <label>Homepage Meta Description</label>
        <textarea name="homepage_meta_description" rows="3"><%= settings.homepage_meta_description %></textarea>

        <label>Hero Title</label>
        <input type="text" name="hero_title" value="<%= settings.hero_title %>" />

        <label>Hero Subtitle</label>
        <textarea name="hero_subtitle" rows="3"><%= settings.hero_subtitle %></textarea>

        <label>Hero Background URL</label>
        <input type="text" name="hero_background" value="<%= settings.hero_background %>" />

        <button type="submit">Simpan Pengaturan</button>
      </form>
    </main>
  </div>
</body>
</html>
