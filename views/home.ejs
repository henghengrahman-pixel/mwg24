<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>
<body>
  <%- include("partials/header") %>

  <%
    const heroBgRaw = settings?.hero_background || "/images/wisata-berastagi-cover.jpg";
    const heroBg = heroBgRaw.startsWith("/public/")
      ? heroBgRaw.replace("/public", "")
      : heroBgRaw;

    function normalizeImagePath(src) {
      if (!src) return "/images/wisata-berastagi-cover.jpg";
      return src.startsWith("/public/") ? src.replace("/public", "") : src;
    }
  %>

  <section
    class="hero"
    style="background-image:linear-gradient(rgba(16,46,31,.58), rgba(16,46,31,.58)), url('<%= heroBg %>')"
  >
    <div class="container hero-inner">
      <div class="hero-content reveal">
        <span class="eyebrow"><%= settings?.site_name || "Wisata Berastagi" %></span>

        <h1>
          <%= settings?.hero_title || "Wisata Berastagi – Tempat Wisata, Villa, Hotel, Kuliner & Panduan Liburan" %>
        </h1>

        <p>
          <%= settings?.hero_subtitle || "Temukan tempat wisata Berastagi populer, villa dan hotel nyaman, kuliner khas Karo, serta berita dan panduan liburan lengkap untuk menikmati suasana terbaik di Berastagi, Kabupaten Karo, Sumatera Utara." %>
        </p>

        <form class="search-box" action="/cari" method="get" role="search" aria-label="Cari informasi wisata Berastagi">
          <input
            type="text"
            name="q"
            placeholder="Cari tempat wisata, villa, kuliner, berita..."
          />
          <button type="submit">Cari Sekarang</button>
        </form>

        <div class="meta-row" style="margin-top:18px; flex-wrap:wrap;">
          <a href="/wisata" class="btn-secondary">Tempat Wisata</a>
          <a href="/villa" class="btn-secondary">Villa & Hotel</a>
          <a href="/kuliner" class="btn-secondary">Kuliner</a>
          <a href="/berita" class="btn-secondary">Berita</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="intro-box reveal">
        <span class="eyebrow">Panduan Liburan Berastagi</span>
        <h2>Panduan Wisata Berastagi Lengkap untuk Liburan yang Lebih Mudah dan Menyenangkan</h2>
        <p>
          Berastagi menjadi salah satu destinasi wisata favorit di Sumatera Utara karena terkenal dengan udara sejuk,
          pemandangan pegunungan, serta banyak pilihan tempat menarik untuk keluarga, pasangan, maupun rombongan.
          Mulai dari Bukit Gundaling, Gunung Sibayak, Pasar Buah Berastagi, hingga berbagai tempat makan dan
          penginapan nyaman, semuanya membuat liburan di Berastagi terasa lebih seru dan berkesan.
        </p>
        <p>
          Di sini kamu bisa menemukan informasi wisata Berastagi yang lebih lengkap dan mudah dipahami, mulai dari
          tempat wisata populer, rekomendasi villa dan hotel, kuliner khas Karo, berita terbaru, hingga tips liburan
          yang membantu perjalanan ke Berastagi jadi lebih praktis, nyaman, dan menyenangkan.
        </p>
      </div>
    </div>
  </section>

  <section class="section home-section">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">Destinasi Populer</span>
          <h2 class="section-title">Tempat Wisata Populer di Berastagi</h2>
          <div class="section-divider"></div>
        </div>
        <a href="/wisata" class="text-link">Lihat semua</a>
      </div>

      <% if (featuredWisata && featuredWisata.length) { %>
        <div class="card-grid">
          <% featuredWisata.forEach(item => { %>
            <article class="card reveal">
              <a href="/wisata/<%= item.slug %>">
                <img
                  src="<%= normalizeImagePath(item.image) %>"
                  alt="<%= item.title %> di Berastagi"
                  loading="lazy"
                />
                <div class="card-body">
                  <h3><%= item.title %></h3>
                  <p><%= item.excerpt || "Temukan informasi lengkap tempat wisata menarik di Berastagi untuk liburan yang lebih seru dan nyaman." %></p>
                  <div class="meta-row">
                    <span><%= item.location || "Berastagi" %></span>
                  </div>
                  <span class="read-more">Baca Selengkapnya</span>
                </div>
              </a>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state reveal">
          <h3>Belum ada wisata unggulan</h3>
          <p>Data tempat wisata akan tampil di sini setelah ditambahkan dari panel admin.</p>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section section-muted home-section">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">Penginapan Terbaik</span>
          <h2 class="section-title">Villa dan Hotel di Berastagi</h2>
          <div class="section-divider"></div>
        </div>
        <a href="/villa" class="text-link">Lihat semua</a>
      </div>

      <% if (featuredVilla && featuredVilla.length) { %>
        <div class="card-grid">
          <% featuredVilla.forEach(item => { %>
            <article class="card reveal">
              <a href="/villa/<%= item.slug %>">
                <img
                  src="<%= normalizeImagePath(item.image) %>"
                  alt="<%= item.title %> di Berastagi"
                  loading="lazy"
                />
                <div class="card-body">
                  <h3><%= item.title %></h3>
                  <p><%= item.excerpt || "Temukan pilihan villa dan hotel di Berastagi yang nyaman untuk keluarga, pasangan, maupun rombongan." %></p>
                  <div class="meta-row">
                    <strong><%= item.price ? helpers.formatCurrency(item.price) : "Hubungi untuk harga" %></strong>
                  </div>
                  <span class="read-more">Lihat Detail</span>
                </div>
              </a>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state reveal">
          <h3>Belum ada villa atau hotel unggulan</h3>
          <p>Data penginapan akan tampil di sini setelah ditambahkan dari panel admin.</p>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section home-section">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">Kuliner Favorit</span>
          <h2 class="section-title">Kuliner Berastagi yang Wajib Dicoba</h2>
          <div class="section-divider"></div>
        </div>
        <a href="/kuliner" class="text-link">Lihat semua</a>
      </div>

      <% if (latestKuliner && latestKuliner.length) { %>
        <div class="card-grid">
          <% latestKuliner.forEach(item => { %>
            <article class="card reveal">
              <a href="/kuliner/<%= item.slug %>">
                <img
                  src="<%= normalizeImagePath(item.image) %>"
                  alt="<%= item.title %>"
                  loading="lazy"
                />
                <div class="card-body">
                  <h3><%= item.title %></h3>
                  <p><%= item.excerpt || "Temukan kuliner populer dan tempat makan favorit di Berastagi yang cocok dinikmati saat liburan." %></p>
                  <div class="meta-row">
                    <span><%= item.location || "Berastagi" %></span>
                  </div>
                  <span class="read-more">Baca Selengkapnya</span>
                </div>
              </a>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state reveal">
          <h3>Belum ada data kuliner</h3>
          <p>Rekomendasi kuliner akan tampil di sini setelah ditambahkan dari panel admin.</p>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section section-muted home-section">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">Berita Terbaru</span>
          <h2 class="section-title">Berita Wisata Berastagi Terbaru</h2>
          <div class="section-divider"></div>
        </div>
        <a href="/berita" class="text-link">Lihat semua</a>
      </div>

      <% if (latestBerita && latestBerita.length) { %>
        <div class="card-grid">
          <% latestBerita.forEach(item => { %>
            <article class="card reveal">
              <a href="/berita/<%= item.slug %>">
                <img
                  src="<%= normalizeImagePath(item.image) %>"
                  alt="<%= item.title %>"
                  loading="lazy"
                />
                <div class="card-body">
                  <% if (item.category) { %>
                    <span class="card-tag"><%= item.category %></span>
                  <% } %>
                  <h3><%= item.title %></h3>
                  <p><%= item.excerpt || "Baca berita terbaru seputar wisata, kuliner, villa, hotel, dan tips liburan di Berastagi." %></p>
                  <span class="read-more">Baca Berita</span>
                </div>
              </a>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state reveal">
          <h3>Belum ada berita terbaru</h3>
          <p>Berita akan tampil di sini setelah ditambahkan dari panel admin.</p>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="info-grid">
        <div class="info-card reveal">
          <span class="eyebrow">Rekomendasi Liburan</span>
          <h2>Temukan Tempat Wisata Berastagi, Villa, dan Hotel yang Cocok untuk Liburanmu</h2>
          <p>
            Jelajahi berbagai pilihan wisata Berastagi, mulai dari destinasi alam, tempat healing,
            spot favorit keluarga, hingga villa dan hotel nyaman yang cocok untuk menikmati udara sejuk
            dan suasana khas dataran tinggi Karo.
          </p>
        </div>

        <div class="info-card reveal">
          <span class="eyebrow">Informasi Terbaru</span>
          <h2>Kuliner, Berita, dan Panduan Wisata Berastagi yang Lebih Mudah Dipahami</h2>
          <p>
            Dapatkan informasi kuliner khas Karo, berita wisata Berastagi terbaru, tips perjalanan,
            dan panduan liburan yang membantu kamu merencanakan perjalanan dengan lebih nyaman dan terarah.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container">
      <div class="trust-box reveal">
        <span class="eyebrow">Panduan Wisata Berastagi</span>
        <h2>Informasi Wisata Berastagi yang Mudah Dicari dan Mudah Dipahami</h2>
        <p>
          Temukan tempat wisata Berastagi populer, villa dan hotel nyaman, kuliner khas Karo,
          serta berita dan tips liburan yang membantu perjalanan jadi lebih mudah, nyaman, dan menyenangkan.
          Semua informasi disusun agar pengunjung lebih cepat menemukan destinasi terbaik dan merencanakan
          liburan ke Berastagi dengan lebih praktis.
        </p>
      </div>
    </div>
  </section>

  <% if (galleryItems && galleryItems.length) { %>
    <section class="section home-gallery-section" id="galeri-berastagi">
      <div class="container">
        <div class="section-head gallery-head">
          <div>
            <span class="eyebrow">Galeri Berastagi</span>
            <h2 class="section-title">Keindahan Berastagi dalam Galeri Foto</h2>
            <div class="section-divider"></div>
            <p class="gallery-subtext">
              Nikmati panorama alam, suasana sejuk, dan sudut terbaik Berastagi melalui kumpulan foto pilihan
              yang menampilkan pesona dataran tinggi Karo.
            </p>
          </div>

          <a href="/galeri" class="text-link">Lihat semua galeri</a>
        </div>

        <div class="premium-gallery-grid">
          <% galleryItems.forEach((item, index) => { %>
            <article
              class="premium-gallery-card reveal <%= index === 0 ? 'large' : '' %>"
              data-gallery-item
              data-gallery-image="<%= normalizeImagePath(item.image) %>"
              data-gallery-title="<%= item.title || 'Galeri Berastagi' %>"
              data-gallery-caption="<%= item.caption || '' %>"
              data-gallery-alt="<%= item.alt_text || item.title || 'Galeri Berastagi' %>"
            >
              <div class="premium-gallery-media">
                <img
                  src="<%= normalizeImagePath(item.image) %>"
                  alt="<%= item.alt_text || item.title || 'Galeri Berastagi' %>"
                  loading="lazy"
                />
              </div>

              <div class="premium-gallery-overlay">
                <div class="premium-gallery-text">
                  <h3><%= item.title || "Keindahan Berastagi" %></h3>
                  <% if (item.caption) { %>
                    <p><%= item.caption %></p>
                  <% } %>
                </div>

                <button type="button" class="gallery-zoom-btn" aria-label="Lihat foto galeri">
                  Lihat Foto
                </button>
              </div>
            </article>
          <% }) %>
        </div>
      </div>
    </section>

    <div class="gallery-lightbox" id="galleryLightbox" aria-hidden="true">
      <div class="gallery-lightbox-backdrop" data-lightbox-close></div>

      <div class="gallery-lightbox-dialog" role="dialog" aria-modal="true" aria-label="Galeri Berastagi">
        <button type="button" class="gallery-lightbox-close" data-lightbox-close aria-label="Tutup galeri">
          &times;
        </button>

        <div class="gallery-lightbox-image-wrap">
          <img id="galleryLightboxImage" src="" alt="">
        </div>

        <div class="gallery-lightbox-content">
          <h3 id="galleryLightboxTitle">Galeri Berastagi</h3>
          <p id="galleryLightboxCaption"></p>
        </div>
      </div>
    </div>
  <% } %>

  <%- include("partials/footer", { settings }) %>
</body>
</html>
