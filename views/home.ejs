<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>
<body>
  <%- include("partials/header") %>

  <section
    class="hero"
    style="background-image:linear-gradient(rgba(16,46,31,.56), rgba(16,46,31,.56)), url('<%= settings?.hero_background || "/images/default-cover.jpg" %>')"
  >
    <div class="container hero-inner">
      <div class="hero-content reveal">
        <span class="eyebrow">Wisata Berastagi</span>
        <h1>
          <%= settings?.hero_title || "Wisata Berastagi – Tempat Wisata, Villa, Kuliner, dan Berita Terbaru" %>
        </h1>
        <p>
          <%= settings?.hero_subtitle || "Temukan wisata Berastagi terbaik mulai dari tempat wisata populer, villa dan hotel nyaman, kuliner favorit, hingga berita dan panduan liburan lengkap di Berastagi, Sumatera Utara." %>
        </p>

        <form class="search-box" action="/cari" method="get" role="search" aria-label="Cari informasi wisata Berastagi">
          <input
            type="text"
            name="q"
            placeholder="Cari wisata, villa, kuliner, berita..."
          />
          <button type="submit">Cari Sekarang</button>
        </form>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="intro-box reveal">
        <span class="eyebrow">Panduan Liburan</span>
        <h2>Panduan Lengkap Wisata Berastagi untuk Liburan yang Lebih Mudah</h2>
        <p>
          Wisata Berastagi menjadi salah satu pilihan liburan favorit di Sumatera Utara karena menawarkan
          udara yang sejuk, pemandangan gunung yang indah, dan banyak destinasi menarik untuk keluarga,
          pasangan, maupun rombongan. Mulai dari Bukit Gundaling, Gunung Sibayak, Pasar Buah Berastagi,
          hingga berbagai tempat makan dan penginapan nyaman, semuanya bisa menjadi pilihan terbaik
          untuk menghabiskan waktu di dataran tinggi Karo.
        </p>
        <p>
          Melalui website ini, pengunjung bisa menemukan informasi lengkap tentang wisata Berastagi,
          mulai dari tempat wisata di Berastagi, rekomendasi villa dan hotel, kuliner favorit,
          berita terbaru, panduan perjalanan, hingga ide liburan yang membantu merencanakan perjalanan
          dengan lebih praktis dan nyaman.
        </p>
      </div>
    </div>
  </section>

  <section class="section home-section">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">Destinasi Populer</span>
          <h2 class="section-title">Tempat Wisata Populer di Berastagi</h2>
          <div class="section-divider"></div>
        </div>
        <a href="/wisata" class="text-link">Lihat semua</a>
      </div>

      <% if (featuredWisata && featuredWisata.length) { %>
        <div class="card-grid">
          <% featuredWisata.forEach(item => { %>
            <article class="card reveal">
              <a href="/wisata/<%= item.slug %>">
                <img
                  src="<%= item.image || '/images/default-cover.jpg' %>"
                  alt="<%= item.title %> di Berastagi"
                  loading="lazy"
                />
                <div class="card-body">
                  <h3><%= item.title %></h3>
                  <p><%= item.excerpt || 'Temukan informasi lengkap tempat wisata menarik di Berastagi.' %></p>
                  <div class="meta-row">
                    <span><%= item.location || "Berastagi" %></span>
                  </div>
                </div>
              </a>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state reveal">
          <h3>Belum ada wisata unggulan</h3>
          <p>Data tempat wisata akan tampil di sini setelah ditambahkan dari panel admin.</p>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section section-muted home-section">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">Penginapan Terbaik</span>
          <h2 class="section-title">Villa dan Hotel di Berastagi</h2>
          <div class="section-divider"></div>
        </div>
        <a href="/villa" class="text-link">Lihat semua</a>
      </div>

      <% if (featuredVilla && featuredVilla.length) { %>
        <div class="card-grid">
          <% featuredVilla.forEach(item => { %>
            <article class="card reveal">
              <a href="/villa/<%= item.slug %>">
                <img
                  src="<%= item.image || '/images/default-cover.jpg' %>"
                  alt="<%= item.title %> di Berastagi"
                  loading="lazy"
                />
                <div class="card-body">
                  <h3><%= item.title %></h3>
                  <p><%= item.excerpt || 'Temukan villa dan hotel nyaman di Berastagi untuk liburanmu.' %></p>
                  <div class="meta-row">
                    <strong><%= helpers.formatCurrency(item.price) %></strong>
                  </div>
                </div>
              </a>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state reveal">
          <h3>Belum ada villa atau hotel unggulan</h3>
          <p>Data penginapan akan tampil di sini setelah ditambahkan dari panel admin.</p>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section home-section">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">Kuliner Favorit</span>
          <h2 class="section-title">Kuliner Berastagi Terbaru</h2>
          <div class="section-divider"></div>
        </div>
        <a href="/kuliner" class="text-link">Lihat semua</a>
      </div>

      <% if (latestKuliner && latestKuliner.length) { %>
        <div class="card-grid">
          <% latestKuliner.forEach(item => { %>
            <article class="card reveal">
              <a href="/kuliner/<%= item.slug %>">
                <img
                  src="<%= item.image || '/images/default-cover.jpg' %>"
                  alt="<%= item.title %>"
                  loading="lazy"
                />
                <div class="card-body">
                  <h3><%= item.title %></h3>
                  <p><%= item.excerpt || 'Temukan kuliner populer dan tempat makan favorit di Berastagi.' %></p>
                  <div class="meta-row">
                    <span><%= item.location || "Berastagi" %></span>
                  </div>
                </div>
              </a>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state reveal">
          <h3>Belum ada data kuliner</h3>
          <p>Rekomendasi kuliner akan tampil di sini setelah ditambahkan dari panel admin.</p>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section section-muted home-section">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">Berita Terbaru</span>
          <h2 class="section-title">Berita Wisata Berastagi Terbaru</h2>
          <div class="section-divider"></div>
        </div>
        <a href="/berita" class="text-link">Lihat semua</a>
      </div>

      <% if (latestBerita && latestBerita.length) { %>
        <div class="card-grid">
          <% latestBerita.forEach(item => { %>
            <article class="card reveal">
              <a href="/berita/<%= item.slug %>">
                <img
                  src="<%= item.image || '/images/default-cover.jpg' %>"
                  alt="<%= item.title %>"
                  loading="lazy"
                />
                <div class="card-body">
                  <% if (item.category) { %>
                    <span class="card-tag"><%= item.category %></span>
                  <% } %>
                  <h3><%= item.title %></h3>
                  <p><%= item.excerpt || 'Baca berita terbaru seputar wisata, kuliner, villa, dan tips liburan di Berastagi.' %></p>
                </div>
              </a>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state reveal">
          <h3>Belum ada berita terbaru</h3>
          <p>Berita akan tampil di sini setelah ditambahkan dari panel admin.</p>
        </div>
      <% } %>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="info-grid">
        <div class="info-card reveal">
          <span class="eyebrow">Rekomendasi Liburan</span>
          <h2>Temukan Wisata Berastagi, Villa, dan Hotel yang Cocok untuk Kamu</h2>
          <p>
            Kami menyajikan berbagai pilihan wisata Berastagi, mulai dari destinasi populer,
            tempat healing bernuansa alam, hingga penginapan nyaman untuk keluarga dan pasangan
            yang ingin menikmati liburan di Berastagi.
          </p>
        </div>

        <div class="info-card reveal">
          <span class="eyebrow">Update Informasi</span>
          <h2>Kuliner dan Berita Wisata Berastagi yang Mudah Dipahami</h2>
          <p>
            Baca panduan wisata Berastagi, tips perjalanan, rekomendasi kuliner, serta berita terbaru
            tentang tempat menarik di Berastagi agar rencana liburanmu lebih matang dan nyaman.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container">
      <div class="trust-box reveal">
        <span class="eyebrow">Kenapa Pilih Kami</span>
        <h2>Panduan Wisata Berastagi yang Ramah Pengunjung</h2>
        <p>
          Website ini dibuat untuk membantu pengunjung menemukan informasi wisata Berastagi
          dengan lebih cepat, nyaman, dan jelas. Mulai dari tempat wisata populer, villa dan hotel,
          kuliner favorit, hingga berita dan panduan liburan, semuanya disusun agar mudah dicari
          dan enak dibuka di HP maupun desktop.
        </p>
      </div>
    </div>
  </section>

  <%- include("partials/footer", { settings }) %>
</body>
</html>
