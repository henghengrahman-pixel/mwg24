<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>
<body class="admin-page">
  <div class="admin-layout">
    <%- include("partials/admin-sidebar") %>

    <main class="admin-main">
      <div class="admin-head">
        <div>
          <h1>Kelola Kuliner</h1>
          <p class="admin-subtitle">
            Atur daftar kuliner terbaik, tempat makan populer, dan rekomendasi kuliner di Berastagi.
          </p>
        </div>
        <a href="/admin/kuliner/new" class="btn-primary">Tambah Kuliner</a>
      </div>

      <div class="table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th style="width: 11%;">Gambar</th>
              <th style="width: 29%;">Judul</th>
              <th style="width: 18%;">Lokasi</th>
              <th style="width: 14%;">Harga</th>
              <th style="width: 12%;">Unggulan</th>
              <th style="width: 16%;">Aksi</th>
            </tr>
          </thead>

          <tbody>
            <% if (items && items.length) { %>
              <% items.forEach(item => { %>
                <tr>
                  <td>
                    <div class="table-thumb">
                      <img
                        src="<%= item.image || '/images/default-cover.jpg' %>"
                        alt="<%= item.title %>"
                        loading="lazy"
                      >
                    </div>
                  </td>

                  <td>
                    <div class="table-title-cell">
                      <strong><%= item.title %></strong>

                      <% if (item.excerpt) { %>
                        <div class="table-muted">
                          <%= item.excerpt.length > 100 ? item.excerpt.slice(0, 100) + "..." : item.excerpt %>
                        </div>
                      <% } %>

                      <% if (item.slug) { %>
                        <div class="table-slug">/<%= item.slug %></div>
                      <% } %>
                    </div>
                  </td>

                  <td>
                    <span class="table-muted"><%= item.location || "-" %></span>
                  </td>

                  <td>
                    <span class="status-badge"><%= item.price_range || "-" %></span>
                  </td>

                  <td>
                    <% if (Number(item.is_featured) === 1) { %>
                      <span class="status-badge success">Ya</span>
                    <% } else { %>
                      <span class="status-badge muted">Tidak</span>
                    <% } %>
                  </td>

                  <td class="actions">
                    <a href="/admin/kuliner/edit/<%= item.id %>" class="btn-action btn-edit">Edit</a>

                    <form
                      action="/admin/kuliner/delete/<%= item.id %>"
                      method="post"
                      onsubmit="return confirm('Hapus data kuliner ini?')"
                    >
                      <button type="submit" class="btn-action btn-delete">Hapus</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="6">
                  <div class="empty-state">
                    <strong>Belum ada data kuliner.</strong>
                    <p>Silakan tambahkan kuliner baru agar tampil di website.</p>
                  </div>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </main>
  </div>
</body>
</html>
