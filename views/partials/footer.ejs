<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-grid">
      <div class="footer-col footer-brand">
        <span class="eyebrow">Portal Wisata Berastagi</span>
        <h3><%= settings?.site_name || "Wisata Berastagi" %></h3>
        <p>
          <%= settings?.footer_text || "Portal informasi wisata Berastagi yang membahas tempat wisata populer, villa dan hotel, kuliner khas Karo, galeri, berita terbaru, dan panduan liburan di Kabupaten Karo, Sumatera Utara." %>
        </p>
      </div>

      <div class="footer-col">
        <h4>Jelajahi Berastagi</h4>
        <ul class="footer-links">
          <li><a href="/">Beranda</a></li>
          <li><a href="/wisata">Tempat Wisata</a></li>
          <li><a href="/villa">Villa &amp; Hotel</a></li>
          <li><a href="/kuliner">Kuliner</a></li>
          <li><a href="/berita">Berita</a></li>
          <li><a href="/galeri">Galeri</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Informasi Website</h4>
        <ul class="footer-links">
          <li><a href="/about">Tentang Kami</a></li>
          <li><a href="/contact">Kontak</a></li>
          <li><a href="/privacy-policy">Privacy Policy</a></li>
          <li><a href="/disclaimer">Disclaimer</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Kontak Kami</h4>
        <ul class="footer-contact">
          <li>
            <strong>WhatsApp</strong>
            <% if (settings?.contact_phone) { %>
              <a href="https://wa.me/<%= String(settings.contact_phone).replace(/\D/g,'') %>" target="_blank" rel="noopener noreferrer"><%= settings.contact_phone %></a>
            <% } else { %>
              <span>-</span>
            <% } %>
          </li>
          <li>
            <strong>Email</strong>
            <% if (settings?.contact_email) { %>
              <a href="mailto:<%= settings.contact_email %>"><%= settings.contact_email %></a>
            <% } else { %>
              <span>-</span>
            <% } %>
          </li>
          <li>
            <strong>Alamat</strong>
            <span><%= settings?.address || 'Berastagi, Kabupaten Karo, Sumatera Utara' %></span>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-seo">
      <h4>Pencarian Populer</h4>
      <div class="footer-seo-links">
        <a href="/wisata">Tempat Wisata Berastagi</a>
        <a href="/villa">Villa di Berastagi</a>
        <a href="/villa">Hotel di Berastagi</a>
        <a href="/kuliner">Kuliner Berastagi</a>
        <a href="/berita">Berita Wisata Berastagi</a>
        <a href="/galeri">Galeri Berastagi</a>
        <a href="/wisata">Wisata Alam Berastagi</a>
        <a href="/wisata">Wisata Keluarga di Berastagi</a>
        <a href="/kuliner">Makanan Khas Karo</a>
        <a href="/villa">Penginapan Berastagi</a>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© <%= new Date().getFullYear() %> <%= settings?.site_name || "Wisata Berastagi" %>. All rights reserved.</p>
    </div>
  </div>
</footer>
