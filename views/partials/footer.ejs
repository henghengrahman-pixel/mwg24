<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <h3><%= settings?.site_name || 'Wisata Berastagi' %></h3>
      <p>
        <%= settings?.footer_text || 'Wisata Berastagi adalah panduan wisata lengkap yang membahas tempat wisata, vila dan hotel, kuliner, serta tips liburan terbaik di Berastagi, Sumatera Utara.' %>
      </p>
    </div>

    <div>
      <h4>Menu Cepat</h4>
      <ul class="footer-links">
        <li><a href="/">Home</a></li>
        <li><a href="/wisata">Tempat Wisata</a></li>
        <li><a href="/villa">Vila &amp; Hotel</a></li>
        <li><a href="/artikel">Artikel</a></li>
        <li><a href="/tentang">Tentang</a></li>
        <li><a href="/kontak">Kontak</a></li>
      </ul>
    </div>

    <div>
      <h4>Kontak Kami</h4>
      <ul class="footer-links">
        <li>
          HP/WA:
          <% if (settings?.contact_phone) { %>
            <a href="tel:<%= settings.contact_phone %>"><%= settings.contact_phone %></a>
          <% } else { %>
            <span>-</span>
          <% } %>
        </li>
        <li>
          Email:
          <% if (settings?.contact_email) { %>
            <a href="mailto:<%= settings.contact_email %>"><%= settings.contact_email %></a>
          <% } else { %>
            <span>-</span>
          <% } %>
        </li>
        <li>
          Alamat:
          <%= settings?.address || 'Berastagi, Kabupaten Karo, Sumatera Utara' %>
        </li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>© <%= currentYear %> <%= settings?.site_name || 'Wisata Berastagi' %>. All rights reserved.</p>
  </div>
</footer>
