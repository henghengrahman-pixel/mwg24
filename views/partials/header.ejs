<header class="site-header">
  <div class="container nav-wrap">
    <a href="/" class="logo" aria-label="Wisata Berastagi">
      <span class="logo-badge">WB</span>
      <span>
        <strong>Wisata Berastagi</strong>
        <small>Tempat wisata, vila, hotel & kuliner</small>
      </span>
    </a>

    <button
      class="menu-toggle"
      aria-label="Buka menu navigasi"
      aria-controls="mainNav"
      aria-expanded="false"
      onclick="toggleMenu()"
      type="button"
    >
      ☰
    </button>

    <nav class="main-nav" id="mainNav">
      <a href="/" class="<%= path === '/' ? 'active' : '' %>">Home</a>
      <a href="/wisata" class="<%= path.startsWith('/wisata') ? 'active' : '' %>">Tempat Wisata</a>
      <a href="/villa" class="<%= path.startsWith('/villa') ? 'active' : '' %>">Vila &amp; Hotel</a>
      <a href="/artikel" class="<%= path.startsWith('/artikel') ? 'active' : '' %>">Artikel</a>
      <a href="/tentang" class="<%= path === '/tentang' ? 'active' : '' %>">Tentang</a>
      <a href="/kontak" class="<%= path === '/kontak' ? 'active' : '' %>">Kontak</a>
    </nav>
  </div>
</header>
