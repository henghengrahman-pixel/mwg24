<header class="site-header">
  <div class="container nav-wrap">
    <a
      href="/"
      class="logo-text"
      aria-label="Wisata Berastagi - Kembali ke beranda"
    >
      <strong class="site-title">
        <%= settings?.site_name || "Wisata Berastagi" %>
      </strong>
      <small class="site-tagline">
        <%= settings?.site_tagline || "Panduan tempat wisata, villa, kuliner & berita Berastagi" %>
      </small>
    </a>

    <button
      class="menu-toggle"
      type="button"
      aria-label="Buka menu navigasi"
      aria-controls="mainNav"
      aria-expanded="false"
      onclick="toggleMenu()"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="main-nav" id="mainNav" aria-label="Navigasi utama">
      <a href="/" class="<%= (path || '') === '/' ? 'active' : '' %>">
        Beranda
      </a>

      <a href="/wisata" class="<%= (path || '').startsWith('/wisata') ? 'active' : '' %>">
        Tempat Wisata
      </a>

      <a href="/villa" class="<%= (path || '').startsWith('/villa') ? 'active' : '' %>">
        Villa &amp; Hotel
      </a>

      <a href="/kuliner" class="<%= (path || '').startsWith('/kuliner') ? 'active' : '' %>">
        Kuliner
      </a>

      <a href="/berita" class="<%= (path || '').startsWith('/berita') ? 'active' : '' %>">
        Berita
      </a>

      <a href="/galeri" class="<%= (path || '').startsWith('/galeri') ? 'active' : '' %>">
        Galeri
      </a>

      <a href="/about" class="<%= (path || '') === '/about' ? 'active' : '' %>">
        Tentang
      </a>

      <a href="/contact" class="<%= (path || '') === '/contact' ? 'active' : '' %>">
        Kontak
      </a>
    </nav>
  </div>

  <div class="mobile-nav-backdrop" id="mobileNavBackdrop" onclick="closeMenu()"></div>
</header>

<script>
  function toggleMenu() {
    const nav = document.getElementById("mainNav");
    const button = document.querySelector(".menu-toggle");
    const backdrop = document.getElementById("mobileNavBackdrop");
    const isOpen = nav.classList.contains("open");

    if (isOpen) {
      nav.classList.remove("open");
      button.classList.remove("active");
      backdrop.classList.remove("show");
      button.setAttribute("aria-expanded", "false");
      document.body.classList.remove("nav-open");
    } else {
      nav.classList.add("open");
      button.classList.add("active");
      backdrop.classList.add("show");
      button.setAttribute("aria-expanded", "true");
      document.body.classList.add("nav-open");
    }
  }

  function closeMenu() {
    const nav = document.getElementById("mainNav");
    const button = document.querySelector(".menu-toggle");
    const backdrop = document.getElementById("mobileNavBackdrop");

    nav.classList.remove("open");
    button.classList.remove("active");
    backdrop.classList.remove("show");
    button.setAttribute("aria-expanded", "false");
    document.body.classList.remove("nav-open");
  }

  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape") closeMenu();
  });

  window.addEventListener("resize", function () {
    if (window.innerWidth > 980) closeMenu();
  });
</script>
