<header class="site-header">
  <div class="container nav-wrap">
    <a
      href="/"
      class="logo-text"
      aria-label="Wisata Berastagi - Kembali ke beranda"
    >
      <span class="logo-badge" aria-hidden="true">WB</span>

      <span class="logo-copy">
        <strong class="site-title">
          <%= settings?.site_name || "Wisata Berastagi" %>
        </strong>
        <small class="site-tagline">
          <%= settings?.site_tagline || "Panduan tempat wisata, villa, kuliner & berita Berastagi" %>
        </small>
      </span>
    </a>

    <button
      class="menu-toggle"
      type="button"
      aria-label="Buka menu navigasi"
      aria-controls="mainNav"
      aria-expanded="false"
      onclick="toggleMenu()"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="main-nav" id="mainNav" aria-label="Navigasi utama">
      <a href="/" class="<%= (path || '') === '/' ? 'active' : '' %>">
        Beranda
      </a>

      <a href="/wisata" class="<%= (path || '').startsWith('/wisata') ? 'active' : '' %>">
        Tempat Wisata
      </a>

      <a href="/villa" class="<%= (path || '').startsWith('/villa') ? 'active' : '' %>">
        Villa &amp; Hotel
      </a>

      <a href="/kuliner" class="<%= (path || '').startsWith('/kuliner') ? 'active' : '' %>">
        Kuliner
      </a>

      <a href="/berita" class="<%= (path || '').startsWith('/berita') ? 'active' : '' %>">
        Berita
      </a>

      <a href="/galeri" class="<%= (path || '').startsWith('/galeri') ? 'active' : '' %>">
        Galeri
      </a>

      <a href="/about" class="<%= (path || '') === '/about' ? 'active' : '' %>">
        Tentang
      </a>

      <a href="/contact" class="<%= (path || '') === '/contact' ? 'active' : '' %>">
        Kontak
      </a>
    </nav>
  </div>

  <div
    class="mobile-nav-backdrop"
    id="mobileNavBackdrop"
    onclick="closeMenu()"
    aria-hidden="true"
  ></div>
</header>

<script>
  function getMenuElements() {
    return {
      nav: document.getElementById("mainNav"),
      button: document.querySelector(".menu-toggle"),
      backdrop: document.getElementById("mobileNavBackdrop")
    };
  }

  function openMenu() {
    const { nav, button, backdrop } = getMenuElements();
    if (!nav || !button || !backdrop) return;

    nav.classList.add("open");
    button.classList.add("active");
    backdrop.classList.add("show");
    button.setAttribute("aria-expanded", "true");
    document.body.classList.add("nav-open");
  }

  function closeMenu() {
    const { nav, button, backdrop } = getMenuElements();
    if (!nav || !button || !backdrop) return;

    nav.classList.remove("open");
    button.classList.remove("active");
    backdrop.classList.remove("show");
    button.setAttribute("aria-expanded", "false");
    document.body.classList.remove("nav-open");
  }

  function toggleMenu() {
    const { nav } = getMenuElements();
    if (!nav) return;

    if (nav.classList.contains("open")) {
      closeMenu();
    } else {
      openMenu();
    }
  }

  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape") {
      closeMenu();
    }
  });

  window.addEventListener("resize", function () {
    if (window.innerWidth > 980) {
      closeMenu();
    }
  });

  document.addEventListener("click", function (e) {
    const { nav, button } = getMenuElements();
    if (!nav || !button) return;
    if (window.innerWidth > 980) return;

    const clickedInsideNav = nav.contains(e.target);
    const clickedButton = button.contains(e.target);

    if (!clickedInsideNav && !clickedButton && nav.classList.contains("open")) {
      closeMenu();
    }
  });

  document.addEventListener("DOMContentLoaded", function () {
    const navLinks = document.querySelectorAll("#mainNav a");
    navLinks.forEach(function (link) {
      link.addEventListener("click", function () {
        if (window.innerWidth <= 980) {
          closeMenu();
        }
      });
    });
  });
</script>
