<header class="site-header">
  <div class="container nav-wrap">

    <a href="/" class="logo-text">
      <strong class="site-title">Wisata Berastagi</strong>
      <small class="site-tagline">Tempat wisata, vila, hotel & kuliner</small>
    </a>

    <button class="menu-toggle" aria-label="Buka menu" onclick="toggleMenu()">☰</button>

    <nav class="main-nav" id="mainNav">
      <a href="/" class="<%= path === '/' ? 'active' : '' %>">Home</a>
      <a href="/wisata" class="<%= path.startsWith('/wisata') ? 'active' : '' %>">Wisata</a>
      <a href="/villa" class="<%= path.startsWith('/villa') ? 'active' : '' %>">Vila & Hotel</a>
      <a href="/artikel" class="<%= path.startsWith('/artikel') ? 'active' : '' %>">Artikel</a>
      <a href="/tentang" class="<%= path === '/tentang' ? 'active' : '' %>">Tentang</a>
      <a href="/kontak" class="<%= path === '/kontak' ? 'active' : '' %>">Kontak</a>
    </nav>

  </div>
</header>
