<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <%
    const safeSettings = settings || {};
    const safeSeo = seo || {};
    const siteName = safeSettings.site_name || "Wisata Berastagi";
    const defaultTitle = `${siteName} – Tempat Wisata, Villa, Kuliner, dan Berita Terbaru`;
    const defaultDescription =
      safeSettings.homepage_meta_description ||
      "Wisata Berastagi adalah panduan lengkap tempat wisata di Berastagi Sumatera Utara, mulai dari destinasi populer, villa dan hotel, kuliner, berita terbaru, hingga tips liburan terbaik.";
    const canonicalUrl = safeSeo.canonical || `${baseUrl}${path || ""}`;
    const rawImage = safeSeo.image || safeSettings.hero_background || "/images/default-cover.jpg";
    const imageUrl = /^https?:\/\//i.test(rawImage) ? rawImage : `${baseUrl}${rawImage}`;
    const pageTitle = safeSeo.title || defaultTitle;
    const pageDescription = safeSeo.description || defaultDescription;
    const pageType = safeSeo.type || "website";
  %>

  <title><%= pageTitle %></title>

  <meta name="description" content="<%= pageDescription %>">
  <meta
    name="robots"
    content="<%= safeSeo.noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large' %>"
  >
  <meta name="author" content="<%= siteName %>">
  <meta name="theme-color" content="#1e5b3a">

  <link rel="canonical" href="<%= canonicalUrl %>">

  <!-- FAVICON -->
  <link rel="icon" href="/favicon/favicon.ico" sizes="any">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
  <link rel="icon" type="image/png" sizes="48x48" href="/favicon/favicon-48x48.png">
  <link rel="icon" type="image/png" sizes="64x64" href="/favicon/favicon-64x64.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon/favicon-180x180.png">

  <!-- OPEN GRAPH -->
  <meta property="og:locale" content="id_ID">
  <meta property="og:site_name" content="<%= siteName %>">
  <meta property="og:title" content="<%= pageTitle %>">
  <meta property="og:description" content="<%= pageDescription %>">
  <meta property="og:type" content="<%= pageType %>">
  <meta property="og:url" content="<%= canonicalUrl %>">
  <meta property="og:image" content="<%= imageUrl %>">
  <meta property="og:image:alt" content="<%= pageTitle %>">

  <!-- TWITTER -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= pageTitle %>">
  <meta name="twitter:description" content="<%= pageDescription %>">
  <meta name="twitter:image" content="<%= imageUrl %>">
  <meta name="twitter:url" content="<%= canonicalUrl %>">

  <!-- PRECONNECT -->
  <link rel="preconnect" href="<%= baseUrl %>">

  <!-- CSS -->
  <link rel="stylesheet" href="/css/style.css">

  <!-- JS -->
  <script defer src="/js/main.js"></script>

  <!-- JSON LD SEO -->
  <% if (safeSeo.jsonLd) { %>
    <script type="application/ld+json"><%- safeSeo.jsonLd %></script>
  <% } else { %>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "<%= siteName %>",
        "url": "<%= baseUrl %>",
        "description": "<%= defaultDescription %>",
        "inLanguage": "id-ID",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "<%= baseUrl %>/cari?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    </script>
  <% } %>
</head>
