<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <%
    const safeSettings = settings || {};
    const safeSeo = seo || {};
    const normalizedBaseUrl = String(baseUrl || "").replace(/\/+$/, "");
    const siteName = safeSettings.site_name || "Wisata Berastagi";

    const defaultTitle =
      safeSettings.homepage_meta_title ||
      "Wisata Berastagi – Tempat Wisata, Villa, Hotel, Kuliner & Panduan Liburan";

    const defaultDescription =
      safeSettings.homepage_meta_description ||
      "Panduan wisata Berastagi terlengkap untuk menemukan tempat wisata Berastagi populer, villa dan hotel terbaik, kuliner khas Karo, berita terbaru, serta tips liburan ke Berastagi Kabupaten Karo Sumatera Utara.";

    const canonicalPath = path || "";
    const canonicalUrl = safeSeo.canonical || `${normalizedBaseUrl}${canonicalPath}`;

    const rawImage =
      safeSeo.image ||
      safeSettings.hero_background ||
      "/images/wisata-berastagi-cover.jpg";

    const normalizedImagePath =
      /^https?:\/\//i.test(rawImage)
        ? rawImage
        : rawImage.startsWith("/")
        ? rawImage
        : `/${rawImage}`;

    const imageUrl = /^https?:\/\//i.test(rawImage)
      ? rawImage
      : `${normalizedBaseUrl}${normalizedImagePath}`;

    const pageTitle = safeSeo.title || defaultTitle;
    const pageDescription = safeSeo.description || defaultDescription;
    const pageType = safeSeo.type || "website";
    const pageKeywords =
      safeSeo.keywords ||
      "wisata berastagi, tempat wisata berastagi, villa berastagi, hotel berastagi, kuliner berastagi, liburan berastagi, wisata karo, tempat wisata karo, berita berastagi, penginapan berastagi";

    const organizationLogo =
      safeSettings.logo && /^https?:\/\//i.test(safeSettings.logo)
        ? safeSettings.logo
        : safeSettings.logo
        ? `${normalizedBaseUrl}${safeSettings.logo.startsWith("/") ? safeSettings.logo : "/" + safeSettings.logo}`
        : imageUrl;
  %>

  <title><%= pageTitle %></title>
  <meta name="description" content="<%= pageDescription %>">
  <meta name="keywords" content="<%= pageKeywords %>">
  <meta name="robots" content="<%= safeSeo.noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large' %>">
  <meta name="author" content="<%= siteName %>">
  <meta name="theme-color" content="#1e5b3a">

  <link rel="canonical" href="<%= canonicalUrl %>">

  <!-- FAVICON -->
  <link rel="icon" href="/favicon/favicon.ico" sizes="any">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="48x48" href="/favicon/favicon-48x48.png">
  <link rel="icon" type="image/png" sizes="64x64" href="/favicon/favicon-64x64.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon/favicon-180x180.png">

  <!-- OPEN GRAPH -->
  <meta property="og:locale" content="id_ID">
  <meta property="og:site_name" content="<%= siteName %>">
  <meta property="og:title" content="<%= pageTitle %>">
  <meta property="og:description" content="<%= pageDescription %>">
  <meta property="og:type" content="<%= pageType %>">
  <meta property="og:url" content="<%= canonicalUrl %>">
  <meta property="og:image" content="<%= imageUrl %>">
  <meta property="og:image:secure_url" content="<%= imageUrl %>">
  <meta property="og:image:alt" content="<%= pageTitle %>">
  <meta property="og:image:type" content="image/jpeg">

  <!-- TWITTER -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= pageTitle %>">
  <meta name="twitter:description" content="<%= pageDescription %>">
  <meta name="twitter:image" content="<%= imageUrl %>">
  <meta name="twitter:image:alt" content="<%= pageTitle %>">
  <meta name="twitter:url" content="<%= canonicalUrl %>">

  <!-- PRECONNECT -->
  <link rel="preconnect" href="<%= normalizedBaseUrl %>" crossorigin>

  <!-- CSS -->
  <link rel="stylesheet" href="/css/style.css">

  <!-- JS -->
  <script defer src="/js/main.js"></script>

  <!-- JSON-LD SEO -->
  <% if (safeSeo.jsonLd) { %>
    <script type="application/ld+json"><%- safeSeo.jsonLd %></script>
  <% } else { %>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "WebSite",
            "@id": "<%= normalizedBaseUrl %>/#website",
            "name": "<%= siteName %>",
            "url": "<%= normalizedBaseUrl %>",
            "description": "<%= defaultDescription %>",
            "inLanguage": "id-ID",
            "potentialAction": {
              "@type": "SearchAction",
              "target": "<%= normalizedBaseUrl %>/cari?q={search_term_string}",
              "query-input": "required name=search_term_string"
            }
          },
          {
            "@type": "Organization",
            "@id": "<%= normalizedBaseUrl %>/#organization",
            "name": "<%= siteName %>",
            "url": "<%= normalizedBaseUrl %>",
            "logo": {
              "@type": "ImageObject",
              "url": "<%= organizationLogo %>"
            }
          },
          {
            "@type": "WebPage",
            "@id": "<%= canonicalUrl %>#webpage",
            "url": "<%= canonicalUrl %>",
            "name": "<%= pageTitle %>",
            "description": "<%= pageDescription %>",
            "isPartOf": {
              "@id": "<%= normalizedBaseUrl %>/#website"
            },
            "about": {
              "@id": "<%= normalizedBaseUrl %>/#organization"
            },
            "inLanguage": "id-ID",
            "primaryImageOfPage": {
              "@type": "ImageObject",
              "url": "<%= imageUrl %>"
            }
          }
        ]
      }
    </script>
  <% } %>
</head>
