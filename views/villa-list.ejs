.villa-grid{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:24px;
}

.villa-card{
  background:#fff;
  border:1px solid #e3ebe5;
  border-radius:22px;
  overflow:hidden;
  box-shadow:0 12px 28px rgba(20,54,36,.06);
  transition:transform .25s ease, box-shadow .25s ease;
}

.villa-card:hover{
  transform:translateY(-4px);
  box-shadow:0 18px 34px rgba(20,54,36,.10);
}

.villa-card-link{
  display:block;
  color:inherit;
  text-decoration:none;
  height:100%;
}

.villa-card-media{
  position:relative;
  aspect-ratio:16/10;
  overflow:hidden;
  background:#edf3ee;
}

.villa-card-media img{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
  transition:transform .35s ease;
}

.villa-card:hover .villa-card-media img{
  transform:scale(1.04);
}

.villa-card-badge{
  position:absolute;
  right:14px;
  bottom:14px;
  display:inline-flex;
  align-items:center;
  gap:6px;
  background:rgba(0,0,0,.65);
  color:#fff;
  padding:8px 10px;
  border-radius:999px;
  font-size:13px;
  font-weight:700;
  backdrop-filter:blur(4px);
}

.villa-card-badge svg{
  width:16px;
  height:16px;
  fill:currentColor;
}

.villa-card-body{
  padding:18px 18px 20px;
}

.villa-card-top{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:12px;
  margin-bottom:10px;
}

.villa-card-top h2{
  margin:0;
  font-size:1.1rem;
  line-height:1.35;
  color:#183124;
}

.villa-card-price{
  white-space:nowrap;
  color:#24593f;
  font-size:.98rem;
}

.villa-card-location{
  margin:0 0 10px;
  font-size:.95rem;
  color:#557062;
}

.villa-card-excerpt{
  margin:0 0 16px;
  color:#4f6558;
  line-height:1.7;
  font-size:.95rem;
}

.villa-card-cta{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  min-height:40px;
  padding:0 14px;
  border-radius:999px;
  background:#edf6ef;
  color:#24593f;
  font-weight:700;
  font-size:.92rem;
}

@media (max-width: 1024px){
  .villa-grid{
    grid-template-columns:repeat(2,minmax(0,1fr));
  }
}

@media (max-width: 640px){
  .villa-grid{
    grid-template-columns:1fr;
    gap:18px;
  }

  .villa-card-top{
    flex-direction:column;
    gap:6px;
  }

  .villa-card-price{
    white-space:normal;
  }
}
