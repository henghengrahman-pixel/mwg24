<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>
<body class="admin-page">
  <div class="admin-layout">
    <%- include("partials/admin-sidebar") %>

    <main class="admin-main">
      <div class="admin-head">
        <div>
          <h1><%= item ? "Edit Galeri" : "Kelola Galeri" %></h1>
          <p class="admin-subtitle">
            Upload foto galeri homepage, atur urutan tampil, caption, alt text SEO, dan status aktif.
          </p>
        </div>
      </div>

      <% if (typeof error !== "undefined" && error) { %>
        <div class="alert-error"><%= error %></div>
      <% } %>

      <div class="admin-card">
        <h2><%= item ? "Edit Foto Galeri" : "Tambah Foto Galeri" %></h2>

        <form action="/admin/gallery/save" method="post" enctype="multipart/form-data" class="admin-form">
          <input type="hidden" name="id" value="<%= item?.id || '' %>">
          <input type="hidden" name="current_image" value="<%= item?.image || '' %>">

          <div class="form-grid">
            <div class="form-group full">
              <label for="title">Judul Foto</label>
              <input
                type="text"
                id="title"
                name="title"
                value="<%= item?.title || '' %>"
                placeholder="Contoh: Keindahan Bukit Gundaling Berastagi"
              >
            </div>

            <div class="form-group full">
              <label for="slug">Slug</label>
              <input
                type="text"
                id="slug"
                name="slug"
                value="<%= item?.slug || '' %>"
                placeholder="otomatis jika kosong"
              >
              <small class="form-hint">Dipakai untuk identitas data galeri.</small>
            </div>

            <div class="form-group full">
              <label for="alt_text">Alt Text SEO</label>
              <input
                type="text"
                id="alt_text"
                name="alt_text"
                value="<%= item?.alt_text || '' %>"
                placeholder="Contoh: Pemandangan Bukit Gundaling Berastagi Sumatera Utara"
              >
            </div>

            <div class="form-group full">
              <label for="caption">Caption</label>
              <textarea
                id="caption"
                name="caption"
                rows="3"
                placeholder="Deskripsi singkat foto untuk ditampilkan di homepage"
              ><%= item?.caption || '' %></textarea>
            </div>

            <div class="form-group">
              <label for="sort_order">Urutan Tampil</label>
              <input
                type="number"
                id="sort_order"
                name="sort_order"
                value="<%= item?.sort_order ?? 0 %>"
                placeholder="0"
              >
              <small class="form-hint">Angka lebih kecil tampil lebih dulu.</small>
            </div>

            <div class="form-group">
              <label class="checkbox-line" style="margin-top:30px;">
                <input
                  type="checkbox"
                  name="is_active"
                  value="1"
                  <%= Number(item?.is_active ?? 1) === 1 ? "checked" : "" %>
                >
                Tampilkan di homepage
              </label>
            </div>

            <div class="form-group full">
              <label for="image_url">URL Foto</label>

              <% if (item?.image) { %>
                <div class="image-preview">
                  <img src="<%= item.image %>" alt="<%= item.alt_text || item.title || 'Preview Galeri' %>">
                </div>
              <% } %>

              <input type="text" id="image_url" name="image_url" value="<%= item?.image || '' %>" placeholder="https://... atau /images/...">
              <small class="form-hint">Galeri wajib pakai link gambar. Tidak upload file ke volume Railway.</small>
            </div>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn-primary">
              <%= item ? "Update Foto" : "Simpan Foto" %>
            </button>

            <% if (item) { %>
              <a href="/admin/gallery" class="btn-secondary">Batal Edit</a>
            <% } %>
          </div>
        </form>
      </div>

      <div class="admin-card">
        <div class="admin-head" style="margin-bottom:16px;">
          <div>
            <h2 style="margin:0;">Daftar Foto Galeri</h2>
            <p class="admin-subtitle">Foto aktif akan tampil di homepage tepat di atas footer.</p>
          </div>
        </div>

        <% if (!items || !items.length) { %>
          <div class="empty-state">
            <strong>Belum ada foto galeri</strong>
            <p>Tambahkan foto pertama untuk mulai menampilkan galeri premium di homepage.</p>
          </div>
        <% } else { %>
          <div class="table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Foto</th>
                  <th>Judul</th>
                  <th>Alt Text / Caption</th>
                  <th>Urutan</th>
                  <th>Status</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% items.forEach(gal => { %>
                  <tr>
                    <td>
                      <div class="table-thumb">
                        <img src="<%= gal.image %>" alt="<%= gal.alt_text || gal.title || 'Galeri' %>">
                      </div>
                    </td>

                    <td>
                      <div class="table-title-cell">
                        <strong><%= gal.title || "Tanpa Judul" %></strong>
                        <span class="table-slug"><%= gal.slug || "-" %></span>
                      </div>
                    </td>

                    <td>
                      <div class="table-title-cell">
                        <span class="table-muted"><strong>Alt:</strong> <%= gal.alt_text || "-" %></span>
                        <span class="table-muted"><strong>Caption:</strong> <%= gal.caption || "-" %></span>
                      </div>
                    </td>

                    <td><%= gal.sort_order ?? 0 %></td>

                    <td>
                      <% if (Number(gal.is_active) === 1) { %>
                        <span class="status-badge success">Aktif</span>
                      <% } else { %>
                        <span class="status-badge muted">Nonaktif</span>
                      <% } %>
                    </td>

                    <td>
                      <div class="actions">
                        <a href="/admin/gallery/edit/<%= gal.id %>" class="btn-action btn-edit">Edit</a>

                        <form action="/admin/gallery/toggle/<%= gal.id %>" method="post">
                          <button type="submit" class="btn-action btn-edit">
                            <%= Number(gal.is_active) === 1 ? "Nonaktifkan" : "Aktifkan" %>
                          </button>
                        </form>

                        <form action="/admin/gallery/delete/<%= gal.id %>" method="post" onsubmit="return confirm('Hapus foto galeri ini?')">
                          <button type="submit" class="btn-action btn-delete">Hapus</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </main>
  </div>

  <script>
    const titleInput = document.getElementById("title");
    const slugInput = document.getElementById("slug");

    function makeSlug(text) {
      return String(text || "")
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9\\s-]/g, "")
        .replace(/\\s+/g, "-")
        .replace(/-+/g, "-")
        .replace(/^-|-$/g, "");
    }

    if (titleInput && slugInput) {
      titleInput.addEventListener("input", function () {
        if (!slugInput.dataset.editedManually || !slugInput.value.trim()) {
          slugInput.value = makeSlug(titleInput.value);
        }
      });

      slugInput.addEventListener("input", function () {
        slugInput.dataset.editedManually = "true";
      });
    }
  </script>
</body>
</html>
