<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>
<body class="admin-page">
  <div class="admin-layout">
    <%- include("partials/admin-sidebar") %>

    <main class="admin-main">
      <div class="admin-head">
        <div>
          <h1><%= item && item.id ? "Edit Villa" : "Tambah Villa" %></h1>
        </div>
      </div>

      <%
        let galleryImages = [];
        try {
          if (Array.isArray(item?.images)) {
            galleryImages = item.images.filter(Boolean);
          } else if (item?.images) {
            const parsed = JSON.parse(item.images);
            galleryImages = Array.isArray(parsed) ? parsed.filter(Boolean) : [];
          }
        } catch (e) {
          galleryImages = [];
        }
      %>

      <form id="villaForm" action="/admin/villa/save" method="post" class="admin-form">
        <input type="hidden" name="id" value="<%= item?.id || '' %>">

        <div class="form-grid">
          <div class="form-group full">
            <label>Judul</label>
            <input type="text" id="title" name="title" value="<%= item?.title || '' %>" required>
          </div>

          <div class="form-group full">
            <label>Slug</label>
            <input type="text" id="slug" name="slug" value="<%= item?.slug || '' %>">
          </div>

          <div class="form-group full">
            <label>Excerpt</label>
            <textarea name="excerpt"><%= item?.excerpt || '' %></textarea>
          </div>

          <div class="form-group full">
            <label>Konten</label>
            <textarea id="editor" name="content"><%= item?.content || '' %></textarea>
          </div>

          <!-- 🔥 IMAGE URL -->
          <div class="form-group full">
            <label>Gambar Utama (URL)</label>
            <input type="text" id="image" name="image" value="<%= item?.image || '' %>" placeholder="https://..." required>

            <img id="previewImage"
              src="<%= item?.image || '' %>"
              style="max-width:200px;margin-top:10px;<%= item?.image ? '' : 'display:none;' %>">
          </div>

          <!-- 🔥 GALLERY URL -->
          <div class="form-group full">
            <label>Galeri (pisah pakai koma)</label>
            <textarea id="galleryInput" name="images" placeholder="https://img1.jpg, https://img2.jpg"><%= galleryImages.join(', ') %></textarea>

            <div id="galleryPreview" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:10px;margin-top:10px;"></div>
          </div>

          <div class="form-group">
            <label>Harga</label>
            <input type="text" name="price" value="<%= item?.price || '' %>">
          </div>

          <div class="form-group">
            <label>Lokasi</label>
            <input type="text" name="location" value="<%= item?.location || '' %>">
          </div>

          <div class="form-group full">
            <label>Fasilitas</label>
            <input type="text" name="facilities" value="<%= item?.facilities || '' %>">
          </div>

          <div class="form-group">
            <label>Booking URL</label>
            <input type="url" name="booking_url" value="<%= item?.booking_url || '' %>">
          </div>

          <div class="form-group">
            <label>Kontak</label>
            <input type="text" name="contact_phone" value="<%= item?.contact_phone || '' %>">
          </div>

          <div class="form-group full">
            <label>Maps</label>
            <input type="url" name="maps_url" value="<%= item?.maps_url || '' %>">
          </div>

          <div class="form-group full">
            <label>
              <input type="checkbox" name="is_featured" value="1"
              <%= Number(item?.is_featured || 0) === 1 ? "checked" : "" %>>
              Featured
            </label>
          </div>

          <div class="form-group full">
            <label>Meta Title</label>
            <input type="text" name="meta_title" value="<%= item?.meta_title || '' %>">
          </div>

          <div class="form-group full">
            <label>Meta Description</label>
            <textarea name="meta_description"><%= item?.meta_description || '' %></textarea>
          </div>
        </div>

        <button type="submit">Simpan</button>
      </form>
    </main>
  </div>

<script src="https://cdn.jsdelivr.net/npm/tinymce@6/tinymce.min.js"></script>
<script>
tinymce.init({
  selector:"#editor",
  height:400,
  menubar:false,
  plugins:"lists link image code",
  toolbar:"undo redo | bold italic | bullist numlist | link image | code"
});

// slug
const title = document.getElementById("title");
const slug = document.getElementById("slug");

function makeSlug(text){
  return text.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/(^-|-$)/g,'');
}

title.addEventListener("input",()=>{
  if(!slug.value) slug.value = makeSlug(title.value);
});

// preview main image
const imgInput = document.getElementById("image");
const preview = document.getElementById("previewImage");

imgInput.addEventListener("input",()=>{
  const val = imgInput.value.trim();
  if(val){
    preview.src = val;
    preview.style.display="block";
  } else {
    preview.style.display="none";
  }
});

// preview gallery
const galleryInput = document.getElementById("galleryInput");
const galleryPreview = document.getElementById("galleryPreview");

galleryInput.addEventListener("input",()=>{
  galleryPreview.innerHTML = "";
  const urls = galleryInput.value.split(",").map(u=>u.trim()).filter(Boolean);

  urls.forEach(url=>{
    const img = document.createElement("img");
    img.src = url;
    img.style.width="100%";
    img.style.height="100px";
    img.style.objectFit="cover";
    galleryPreview.appendChild(img);
  });
});

// validation
document.getElementById("villaForm").addEventListener("submit",(e)=>{
  tinymce.triggerSave();

  const titleVal = title.value.trim();
  const content = document.getElementById("editor").value.trim();

  if(!titleVal){
    alert("Judul wajib diisi");
    e.preventDefault();
    return;
  }

  if(!content){
    alert("Konten wajib diisi");
    e.preventDefault();
    return;
  }
});
</script>
</body>
</html>
