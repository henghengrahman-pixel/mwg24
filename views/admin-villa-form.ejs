<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>
<body class="admin-page">
  <div class="admin-layout">
    <%- include("partials/admin-sidebar") %>

    <main class="admin-main">
      <div class="admin-head">
        <h1><%= item && item.id ? "Edit Villa" : "Tambah Villa" %></h1>
      </div>

      <%
        let galleryImages = [];
        try {
          galleryImages = JSON.parse(item?.images || "[]");
        } catch (e) {}
      %>

      <form id="villaForm" action="/admin/villa/save" method="post" class="admin-form">
        <input type="hidden" name="id" value="<%= item?.id || '' %>">

        <div class="form-grid">

          <!-- TITLE -->
          <div class="form-group full">
            <input type="text" id="title" name="title" placeholder="Judul" value="<%= item?.title || '' %>" required>
          </div>

          <!-- SLUG -->
          <div class="form-group full">
            <input type="text" id="slug" name="slug" placeholder="Slug" value="<%= item?.slug || '' %>">
          </div>

          <!-- CONTENT -->
          <div class="form-group full">
            <textarea id="editor" name="content"><%= item?.content || '' %></textarea>
          </div>

          <!-- IMAGE URL -->
          <div class="form-group full">
            <label>Gambar Utama (URL)</label>
            <% if (item?.image) { %>
              <img src="<%= item.image %>" style="max-width:200px;margin-bottom:10px;border-radius:10px;">
            <% } %>
            <input type="url" name="image" value="<%= item?.image || '' %>" placeholder="https://...">
          </div>

          <!-- GALLERY -->
          <div class="form-group full">
            <label>Galeri (pisah koma)</label>
            <textarea id="gallery_urls" name="gallery_urls"><%= galleryImages.join(', ') %></textarea>

            <div id="previewGallery" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(100px,1fr));gap:10px;margin-top:10px;"></div>
          </div>

          <!-- INFO -->
          <div class="form-group">
            <input type="text" name="price" placeholder="Harga" value="<%= item?.price || '' %>">
          </div>

          <div class="form-group">
            <input type="text" name="location" placeholder="Lokasi" value="<%= item?.location || '' %>">
          </div>

          <div class="form-group full">
            <input type="text" name="facilities" placeholder="Fasilitas" value="<%= item?.facilities || '' %>">
          </div>

          <div class="form-group">
            <input type="url" name="booking_url" placeholder="Booking URL" value="<%= item?.booking_url || '' %>">
          </div>

          <div class="form-group">
            <input type="text" name="contact_phone" placeholder="Kontak" value="<%= item?.contact_phone || '' %>">
          </div>

          <div class="form-group full">
            <input type="url" name="maps_url" placeholder="Google Maps" value="<%= item?.maps_url || '' %>">
          </div>

          <div class="form-group full">
            <label>
              <input type="checkbox" name="is_featured" value="1" <%= item?.is_featured ? "checked" : "" %>>
              Featured
            </label>
          </div>

          <!-- SEO -->
          <div class="form-group full">
            <input type="text" name="meta_title" placeholder="Meta Title" value="<%= item?.meta_title || '' %>">
          </div>

          <div class="form-group full">
            <textarea name="meta_description" placeholder="Meta Description"><%= item?.meta_description || '' %></textarea>
          </div>

        </div>

        <button type="submit" class="btn-primary">Simpan</button>
      </form>
    </main>
  </div>

<script src="https://cdn.jsdelivr.net/npm/tinymce@6/tinymce.min.js"></script>

<script>
const galleryInput = document.getElementById("gallery_urls");
const preview = document.getElementById("previewGallery");

function renderGallery() {
  preview.innerHTML = "";
  const urls = galleryInput.value.split(",").map(x => x.trim()).filter(Boolean);

  urls.forEach(url => {
    const img = document.createElement("img");
    img.src = url;
    img.style.width = "100%";
    img.style.height = "80px";
    img.style.objectFit = "cover";
    img.style.borderRadius = "8px";
    preview.appendChild(img);
  });
}

if (galleryInput) {
  galleryInput.addEventListener("input", renderGallery);
  renderGallery();
}

tinymce.init({
  selector: "#editor",
  height: 500,
  plugins: "link image code",
  toolbar: "undo redo | bold italic | link image | code",
  automatic_uploads: false,
  paste_data_images: false
});
</script>

</body>
</html>
