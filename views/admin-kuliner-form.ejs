<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>
<body class="admin-page">
  <div class="admin-layout">
    <%- include("partials/admin-sidebar") %>

    <main class="admin-main">
      <div class="admin-head">
        <div>
          <h1><%= item ? "Edit Kuliner" : "Tambah Kuliner" %></h1>
          <p class="admin-subtitle">
            Isi data kuliner dengan lengkap agar tampil rapi, profesional, dan SEO lebih kuat.
          </p>
        </div>
      </div>

      <% if (typeof error !== "undefined" && error) { %>
        <div class="alert-error"><%= error %></div>
      <% } %>

      <form action="/admin/kuliner/save" method="post" enctype="multipart/form-data" class="admin-form">
        <input type="hidden" name="id" value="<%= item?.id || "" %>">
        <input type="hidden" name="current_image" value="<%= item?.image || "" %>">

        <div class="form-grid">
          <div class="form-group full">
            <label for="title">Judul Kuliner</label>
            <input
              type="text"
              id="title"
              name="title"
              value="<%= item?.title || '' %>"
              placeholder="Contoh: Jagung Bakar Favorit di Berastagi"
              required
            >
          </div>

          <div class="form-group full">
            <label for="slug">Slug URL</label>
            <input
              type="text"
              id="slug"
              name="slug"
              value="<%= item?.slug || '' %>"
              placeholder="otomatis-jika-dikosongkan"
            >
            <small class="form-hint">URL akan menjadi: /kuliner/slug-kuliner</small>
          </div>

          <div class="form-group">
            <label for="location">Lokasi</label>
            <input
              type="text"
              id="location"
              name="location"
              value="<%= item?.location || '' %>"
              placeholder="Contoh: Pusat Kota Berastagi"
            >
          </div>

          <div class="form-group">
            <label for="price_range">Range Harga</label>
            <input
              type="text"
              id="price_range"
              name="price_range"
              value="<%= item?.price_range || '' %>"
              placeholder="Contoh: 15.000 - 35.000"
            >
          </div>

          <div class="form-group">
            <label for="open_hours">Jam Buka</label>
            <input
              type="text"
              id="open_hours"
              name="open_hours"
              value="<%= item?.open_hours || '' %>"
              placeholder="Contoh: 09.00 - 22.00"
            >
          </div>

          <div class="form-group">
            <label for="contact_phone">No. Kontak</label>
            <input
              type="text"
              id="contact_phone"
              name="contact_phone"
              value="<%= item?.contact_phone || '' %>"
              placeholder="Contoh: 0812-xxxx-xxxx"
            >
          </div>

          <div class="form-group full">
            <label for="maps_url">Link Google Maps</label>
            <input
              type="url"
              id="maps_url"
              name="maps_url"
              value="<%= item?.maps_url || '' %>"
              placeholder="https://maps.google.com/..."
            >
          </div>

          <div class="form-group full">
            <label for="excerpt">Ringkasan Singkat</label>
            <textarea
              id="excerpt"
              name="excerpt"
              rows="3"
              placeholder="Ringkasan singkat untuk preview card dan kebutuhan SEO."
            ><%= item?.excerpt || '' %></textarea>
          </div>

          <div class="form-group full">
            <label for="content">Deskripsi Lengkap</label>
            <textarea
              id="content"
              name="content"
              rows="10"
              placeholder="Tulis deskripsi lengkap kuliner di sini..."
              required
            ><%= item?.content || '' %></textarea>
          </div>

          <div class="form-group full">
            <label for="image">Gambar Utama</label>

            <% if (item?.image) { %>
              <div class="image-preview">
                <img src="<%= item.image %>" alt="<%= item.title || 'Preview Gambar' %>">
              </div>
            <% } %>

            <input type="file" id="image" name="image" accept="image/*">
            <small class="form-hint">Upload gambar baru jika ingin mengganti gambar sebelumnya.</small>
          </div>

          <div class="form-divider full">Pengaturan SEO</div>

          <div class="form-group full">
            <label for="meta_title">Meta Title</label>
            <input
              type="text"
              id="meta_title"
              name="meta_title"
              value="<%= item?.meta_title || '' %>"
              placeholder="Contoh: Jagung Bakar Berastagi Enak dan Murah | Kuliner Berastagi"
            >
          </div>

          <div class="form-group full">
            <label for="meta_description">Meta Description</label>
            <textarea
              id="meta_description"
              name="meta_description"
              rows="3"
              placeholder="Deskripsi singkat untuk tampil di Google."
            ><%= item?.meta_description || '' %></textarea>
          </div>

          <div class="form-group full">
            <label class="checkbox-label">
              <input
                type="checkbox"
                name="is_featured"
                value="1"
                <%= Number(item?.is_featured) === 1 ? "checked" : "" %>
              >
              Jadikan kuliner unggulan
            </label>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-primary">
            <%= item ? "Update Kuliner" : "Simpan Kuliner" %>
          </button>

          <a href="/admin/kuliner" class="btn-secondary">Batal</a>
        </div>
      </form>
    </main>
  </div>
</body>
</html>
