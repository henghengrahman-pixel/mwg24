<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>
<body class="admin-page">
  <div class="admin-layout">
    <%- include("partials/admin-sidebar") %>
    <main class="admin-main">
      <h1>Moderasi Komentar</h1>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Nama</th>
              <th>Tipe</th>
              <th>Komentar</th>
              <th>Status</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% items.forEach(item => { %>
              <tr>
                <td><%= item.name %></td>
                <td><%= item.item_type %></td>
                <td><%= item.comment %></td>
                <td><%= item.status %></td>
                <td class="actions">
                  <% if (item.status !== 'approved') { %>
                    <form action="/admin/comments/approve/<%= item.id %>" method="post">
                      <button type="submit">Approve</button>
                    </form>
                  <% } %>
                  <form action="/admin/comments/delete/<%= item.id %>" method="post" onsubmit="return confirm('Hapus komentar ini?')">
                    <button type="submit">Hapus</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
  </div>
</body>
</html>
