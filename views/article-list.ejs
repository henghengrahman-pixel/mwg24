<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>
<body>
  <%- include("partials/header") %>
  <section class="page-hero small">
    <div class="container">
      <span class="eyebrow">Artikel</span>
      <h1>Artikel Wisata Berastagi</h1>
      <p>Kumpulan artikel SEO seputar wisata, villa, kuliner, dan liburan di Berastagi.</p>
    </div>
  </section>

  <section class="section container">
    <div class="card-grid">
      <% items.forEach(item => { %>
        <article class="card">
          <a href="/artikel/<%= item.slug %>">
            <img src="<%= item.image %>" alt="<%= item.title %>">
            <div class="card-body">
              <h2><%= item.title %></h2>
              <p><%= item.excerpt %></p>
            </div>
          </a>
        </article>
      <% }) %>
    </div>
  </section>

  <%- include("partials/footer", { settings }) %>
</body>
</html>
