<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>
<body class="admin-page">
  <div class="admin-layout">
    <%- include("partials/admin-sidebar") %>

    <main class="admin-main">
      <div class="admin-head">
        <h1><%= item && item.id ? "Edit Wisata" : "Tambah Wisata" %></h1>
      </div>

      <% if (error) { %>
        <div class="alert-error"><%= error %></div>
      <% } %>

      <form id="wisataForm" action="/admin/wisata/save" method="post" class="admin-form">
        <input type="hidden" name="id" value="<%= item?.id || '' %>">

        <div class="form-grid">

          <!-- TITLE -->
          <div class="form-group full">
            <input type="text" id="title" name="title" placeholder="Judul Wisata" value="<%= item?.title || '' %>" required>
          </div>

          <!-- SLUG -->
          <div class="form-group full">
            <input type="text" id="slug" name="slug" placeholder="Slug" value="<%= item?.slug || '' %>">
          </div>

          <!-- EXCERPT -->
          <div class="form-group full">
            <textarea name="excerpt" placeholder="Ringkasan"><%= item?.excerpt || '' %></textarea>
          </div>

          <!-- CONTENT -->
          <div class="form-group full">
            <textarea id="editor" name="content"><%= item?.content || '' %></textarea>
          </div>

          <!-- IMAGE URL -->
          <div class="form-group full">
            <label>Gambar (URL)</label>
            <% if (item?.image) { %>
              <img src="<%= item.image %>" style="max-width:200px;margin-bottom:10px;border-radius:10px;">
            <% } %>
            <input type="url" name="image" value="<%= item?.image || '' %>" placeholder="https://...">
          </div>

          <!-- INFO -->
          <div class="form-group">
            <input type="text" name="location" placeholder="Lokasi" value="<%= item?.location || '' %>">
          </div>

          <div class="form-group">
            <input type="text" name="ticket_price" placeholder="Harga Tiket" value="<%= item?.ticket_price || '' %>">
          </div>

          <div class="form-group">
            <input type="text" name="open_hours" placeholder="Jam Buka" value="<%= item?.open_hours || '' %>">
          </div>

          <div class="form-group">
            <input type="url" name="maps_url" placeholder="Google Maps" value="<%= item?.maps_url || '' %>">
          </div>

          <div class="form-group full">
            <label>
              <input type="checkbox" name="is_featured" value="1" <%= item?.is_featured ? "checked" : "" %>>
              Featured
            </label>
          </div>

          <!-- SEO -->
          <div class="form-group full">
            <input type="text" name="meta_title" placeholder="Meta Title" value="<%= item?.meta_title || '' %>">
          </div>

          <div class="form-group full">
            <textarea name="meta_description" placeholder="Meta Description"><%= item?.meta_description || '' %></textarea>
          </div>

        </div>

        <button type="submit" class="btn-primary">Simpan</button>
      </form>
    </main>
  </div>

<script src="https://cdn.jsdelivr.net/npm/tinymce@6/tinymce.min.js"></script>

<script>
const titleInput = document.getElementById("title");
const slugInput = document.getElementById("slug");

function makeSlug(text) {
  return String(text || "")
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9\s-]/g, "")
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-")
    .replace(/^-|-$/g, "");
}

if (titleInput && slugInput) {
  titleInput.addEventListener("input", function () {
    if (!slugInput.dataset.manual) {
      slugInput.value = makeSlug(titleInput.value);
    }
  });

  slugInput.addEventListener("input", function () {
    slugInput.dataset.manual = "true";
  });
}

tinymce.init({
  selector: "#editor",
  height: 500,
  plugins: "link image code",
  toolbar: "undo redo | bold italic | link image | code",
  automatic_uploads: false,
  paste_data_images: false
});
</script>

</body>
</html>
