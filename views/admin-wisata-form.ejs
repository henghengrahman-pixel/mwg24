<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>
<body class="admin-page">
  <div class="admin-layout">
    <%- include("partials/admin-sidebar") %>

    <main class="admin-main">
      <div class="admin-head">
        <div>
          <h1><%= item && item.id ? "Edit Wisata" : "Tambah Wisata" %></h1>
          <p class="admin-subtitle">
            Kelola destinasi wisata Berastagi dengan konten yang rapi, informatif, dan ramah SEO.
          </p>
        </div>
      </div>

      <% if (typeof error !== "undefined" && error) { %>
        <div class="alert-error"><%= error %></div>
      <% } %>

      <form
        id="wisataForm"
        action="/admin/wisata/save"
        method="post"
        enctype="multipart/form-data"
        class="admin-form"
      >
        <input type="hidden" name="id" value="<%= item?.id || '' %>">
        <input type="hidden" name="current_image" value="<%= item?.image || '' %>">

        <div class="form-grid">
          <div class="form-group full">
            <label for="title">Judul Wisata</label>
            <input type="text" id="title" name="title" value="<%= item?.title || '' %>" required>
          </div>

          <div class="form-group full">
            <label for="slug">Slug</label>
            <input type="text" id="slug" name="slug" value="<%= item?.slug || '' %>">
          </div>

          <div class="form-group full">
            <label for="excerpt">Excerpt</label>
            <textarea id="excerpt" name="excerpt"><%= item?.excerpt || '' %></textarea>
          </div>

          <div class="form-group full">
            <label for="editor">Konten</label>
            <textarea id="editor" name="content"><%= item?.content || '' %></textarea>
          </div>

          <!-- 🔥 IMAGE FIX -->
          <div class="form-group full">
            <label>Gambar Utama (Upload atau Link)</label>

            <% if (item?.image) { %>
              <div class="image-preview">
                <img src="<%= item.image %>" style="max-width:240px;border-radius:12px;">
              </div>
            <% } %>

            <!-- INPUT LINK -->
            <input type="text" name="image_url" placeholder="https://cdn.com/gambar.jpg">

            <!-- UPLOAD -->
            <input type="file" name="image" accept="image/*">
          </div>

          <div class="form-group">
            <input type="text" name="location" value="<%= item?.location || '' %>" placeholder="Lokasi">
          </div>

          <div class="form-group">
            <input type="text" name="ticket_price" value="<%= item?.ticket_price || '' %>" placeholder="Harga">
          </div>

          <div class="form-group">
            <input type="text" name="open_hours" value="<%= item?.open_hours || '' %>" placeholder="Jam buka">
          </div>

          <div class="form-group">
            <input type="url" name="maps_url" value="<%= item?.maps_url || '' %>" placeholder="Google Maps">
          </div>

          <div class="form-group full">
            <label>
              <input type="checkbox" name="is_featured" value="1"
              <%= Number(item?.is_featured || 0) === 1 ? "checked" : "" %>>
              Featured
            </label>
          </div>

          <div class="form-group full">
            <input type="text" name="meta_title" value="<%= item?.meta_title || '' %>" placeholder="Meta title">
          </div>

          <div class="form-group full">
            <textarea name="meta_description"><%= item?.meta_description || '' %></textarea>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit">
            <%= item && item.id ? "Update" : "Simpan" %>
          </button>
        </div>
      </form>
    </main>
  </div>

<script src="https://cdn.jsdelivr.net/npm/tinymce@6/tinymce.min.js"></script>
<script>
tinymce.init({
  selector: "#editor",
  height: 500,
  plugins: "link image table code",
  toolbar: "undo redo | bold italic | link image | code"
});
</script>

</body>
</html>
