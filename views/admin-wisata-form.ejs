<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>
<body class="admin-page">
  <div class="admin-layout">
    <%- include("partials/admin-sidebar") %>

    <main class="admin-main">
      <div class="admin-head">
        <div>
          <h1><%= item && item.id ? "Edit Wisata" : "Tambah Wisata" %></h1>
          <p class="admin-subtitle">
            Kelola destinasi wisata Berastagi dengan konten yang rapi, informatif, dan ramah SEO.
          </p>
        </div>
      </div>

      <% if (typeof error !== "undefined" && error) { %>
        <div class="alert-error"><%= error %></div>
      <% } %>

      <form
        id="wisataForm"
        action="/admin/wisata/save"
        method="post"
        class="admin-form"
      >
        <input type="hidden" name="id" value="<%= item?.id || '' %>">

        <div class="form-grid">
          <div class="form-group full">
            <label for="title">Judul Wisata</label>
            <input type="text" id="title" name="title" value="<%= item?.title || '' %>" required>
          </div>

          <div class="form-group full">
            <label for="slug">Slug (URL)</label>
            <input type="text" id="slug" name="slug" value="<%= item?.slug || '' %>">
          </div>

          <div class="form-group full">
            <label for="excerpt">Excerpt</label>
            <textarea id="excerpt" name="excerpt"><%= item?.excerpt || '' %></textarea>
          </div>

          <div class="form-divider full">Konten</div>

          <div class="form-group full">
            <label for="editor">Isi Konten</label>
            <textarea id="editor" name="content" rows="14"><%= item?.content || '' %></textarea>
          </div>

          <!-- 🔥 FIX IMAGE -->
          <div class="form-group full">
            <label for="image">Gambar (URL)</label>

            <input
              type="text"
              id="image"
              name="image"
              placeholder="https://domain.com/image.jpg"
              value="<%= item?.image || '' %>"
              required
            >

            <img
              id="previewImage"
              src="<%= item?.image || '' %>"
              style="max-width:240px;margin-top:10px;<%= item?.image ? '' : 'display:none;' %>"
            >
          </div>

          <div class="form-group">
            <label>Lokasi</label>
            <input type="text" name="location" value="<%= item?.location || '' %>">
          </div>

          <div class="form-group">
            <label>Harga Tiket</label>
            <input type="text" name="ticket_price" value="<%= item?.ticket_price || '' %>">
          </div>

          <div class="form-group">
            <label>Jam Buka</label>
            <input type="text" name="open_hours" value="<%= item?.open_hours || '' %>">
          </div>

          <div class="form-group">
            <label>Link Maps</label>
            <input type="url" name="maps_url" value="<%= item?.maps_url || '' %>">
          </div>

          <div class="form-group full">
            <label>
              <input type="checkbox" name="is_featured" value="1"
                <%= Number(item?.is_featured || 0) === 1 ? "checked" : "" %>>
              Jadikan unggulan
            </label>
          </div>

          <div class="form-divider full">SEO</div>

          <div class="form-group full">
            <label>Meta Title</label>
            <input type="text" name="meta_title" value="<%= item?.meta_title || '' %>">
          </div>

          <div class="form-group full">
            <label>Meta Description</label>
            <textarea name="meta_description"><%= item?.meta_description || '' %></textarea>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-primary">
            <%= item && item.id ? "Update Wisata" : "Simpan Wisata" %>
          </button>
        </div>
      </form>
    </main>
  </div>

  <!-- TinyMCE TANPA UPLOAD -->
  <script src="https://cdn.jsdelivr.net/npm/tinymce@6/tinymce.min.js"></script>
  <script>
    tinymce.init({
      selector: "#editor",
      height: 500,
      menubar: false,
      plugins: "lists link image table code",
      toolbar: "undo redo | bold italic | alignleft aligncenter alignright | bullist numlist | link image | code",
      relative_urls: false,
      remove_script_host: false,
      convert_urls: false
    });

    // slug auto
    const title = document.getElementById("title");
    const slug = document.getElementById("slug");

    function makeSlug(text) {
      return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
    }

    title.addEventListener("input", () => {
      if (!slug.value) slug.value = makeSlug(title.value);
    });

    // preview image
    const imgInput = document.getElementById("image");
    const preview = document.getElementById("previewImage");

    imgInput.addEventListener("input", () => {
      const val = imgInput.value.trim();
      if (val) {
        preview.src = val;
        preview.style.display = "block";
      } else {
        preview.style.display = "none";
      }
    });
  </script>
</body>
</html>
