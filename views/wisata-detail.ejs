<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>
<body>
<%- include("partials/header") %>

<%
const baseUrl = locals.baseUrl || '';
const url = `${baseUrl}/wisata/${item.slug}`;
const image = item.image || `${baseUrl}/default.jpg`;
%>

<!-- ================= SEO SCHEMA ================= -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "<%= item.title %>",
  "image": "<%= image %>",
  "description": "<%= (item.meta_description || item.excerpt || '').replace(/"/g,'') %>",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Berastagi",
    "addressRegion": "Sumatera Utara",
    "addressCountry": "ID"
  },
  "url": "<%= url %>"
}
</script>

<script type="application/ld+json">
{
  "@context":"https://schema.org",
  "@type":"BreadcrumbList",
  "itemListElement":[
    {"@type":"ListItem","position":1,"name":"Beranda","item":"<%= baseUrl %>"},
    {"@type":"ListItem","position":2,"name":"Wisata Berastagi","item":"<%= baseUrl %>/wisata"},
    {"@type":"ListItem","position":3,"name":"<%= item.title %>","item":"<%= url %>"}
  ]
}
</script>

<script type="application/ld+json">
{
  "@context":"https://schema.org",
  "@type":"FAQPage",
  "mainEntity":[
    {
      "@type":"Question",
      "name":"Di mana lokasi <%= item.title %>?",
      "acceptedAnswer":{"@type":"Answer","text":"<%= item.title %> berada di <%= item.location || 'Berastagi' %>."}
    },
    {
      "@type":"Question",
      "name":"Berapa harga tiket <%= item.title %>?",
      "acceptedAnswer":{"@type":"Answer","text":"Harga tiket sekitar <%= helpers.formatCurrency(item.ticket_price || 0) %>."}
    },
    {
      "@type":"Question",
      "name":"Jam buka <%= item.title %>?",
      "acceptedAnswer":{"@type":"Answer","text":"Jam buka <%= item.open_hours || 'menyesuaikan lokasi' %>."}
    }
  ]
}
</script>

<section class="section container detail-layout">
<article class="detail-main">

<!-- ================= BREADCRUMB ================= -->
<nav class="breadcrumb">
  <a href="/">Beranda</a> /
  <a href="/wisata">Wisata Berastagi</a> /
  <span><%= item.title %></span>
</nav>

<!-- ================= HERO ================= -->
<img src="<%= image %>" alt="<%= item.title %>" class="detail-cover" loading="lazy">

<h1><%= item.title %> – Wisata Populer di Berastagi</h1>

<p class="detail-subtitle">
  Tempat wisata terbaik di Berastagi dengan pemandangan indah, cocok untuk liburan keluarga dan healing.
</p>

<!-- ================= META ================= -->
<div class="detail-meta">
  <span>📍 <%= item.location %></span>
  <span>🕒 <%= item.open_hours || '-' %></span>
  <span>💰 <%= helpers.formatCurrency(item.ticket_price || 0) %></span>
</div>

<!-- ================= INTRO ================= -->
<p class="detail-intro">
  <%= item.excerpt || ('Informasi lengkap tentang ' + item.title + ' di Berastagi, mulai dari lokasi, harga tiket, fasilitas, hingga tips berkunjung.') %>
</p>

<!-- ================= CONTENT ================= -->
<section id="deskripsi">
<h2>Deskripsi <%= item.title %></h2>

<div class="detail-content article-content">
<%
const raw = item.content || '';
const hasHtml = /<\/?[a-z]/i.test(raw);
%>

<% if (hasHtml) { %>
  <%- raw %>
<% } else { %>
  <%- raw.split(/\n\n/).map(p => `<p>${p}</p>`).join('') %>
<% } %>
</div>
</section>

<!-- ================= INFO ================= -->
<section id="info-wisata">
<h2>Info Lengkap <%= item.title %></h2>

<ul class="info-list">
  <li><strong>Lokasi:</strong> <%= item.location %></li>
  <li><strong>Harga Tiket:</strong> <%= helpers.formatCurrency(item.ticket_price || 0) %></li>
  <li><strong>Jam Buka:</strong> <%= item.open_hours || '-' %></li>
</ul>
</section>

<!-- ================= INTERNAL LINK ================= -->
<section>
<h2>Jelajahi Berastagi</h2>
<p>
  Lihat juga <a href="/wisata">wisata Berastagi lainnya</a>,
  <a href="/villa">villa & hotel</a>,
  <a href="/kuliner">kuliner khas</a>,
  dan <a href="/berita">info terbaru</a>.
</p>
</section>

<!-- ================= RELATED ================= -->
<section id="wisata-terkait">
<h2>Wisata Terkait</h2>

<div class="related-links-grid">
<% if (related && related.length) { %>
  <% related.forEach(r => { %>
    <a href="/wisata/<%= r.slug %>"><%= r.title %></a>
  <% }) %>
<% } else { %>
  <p>Tidak ada data.</p>
<% } %>
</div>
</section>

<!-- ================= FAQ ================= -->
<section id="faq">
<h2>FAQ <%= item.title %></h2>

<h3>Lokasi dimana?</h3>
<p><%= item.location %></p>

<h3>Harga tiket?</h3>
<p><%= helpers.formatCurrency(item.ticket_price || 0) %></p>

<h3>Jam buka?</h3>
<p><%= item.open_hours || '-' %></p>

</section>

<!-- ================= RATING ================= -->
<section id="rating">
<h2>Rating</h2>
<p><strong><%= avg || 0 %>/5</strong> dari <%= ratings.length %> ulasan</p>
</section>

<!-- ================= COMMENT ================= -->
<section id="ulasan">
<h2>Ulasan</h2>

<form action="/wisata/<%= item.slug %>/comment" method="post">
  <input name="name" placeholder="Nama" required>
  <textarea name="comment" required></textarea>
  <button>Kirim</button>
</form>

<% comments.forEach(c => { %>
  <div class="comment">
    <strong><%= c.name %></strong>
    <p><%= c.comment %></p>
  </div>
<% }) %>

</section>

</article>

<!-- ================= SIDEBAR ================= -->
<aside class="detail-sidebar">

<div class="sticky-box">
<h3>Info Cepat</h3>
<p><%= item.location %></p>
<p><%= helpers.formatCurrency(item.ticket_price || 0) %></p>

<% if(item.maps_url){ %>
<a href="<%= item.maps_url %>" target="_blank" class="btn-primary">Google Maps</a>
<% } %>
</div>

<div class="sticky-box">
<h3>Navigasi</h3>
<a href="/villa">Villa</a>
<a href="/kuliner">Kuliner</a>
<a href="/berita">Berita</a>
</div>

</aside>

</section>

<%- include("partials/footer") %>
</body>
</html>
