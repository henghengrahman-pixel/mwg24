<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>
<body>
  <%- include("partials/header") %>

  <section class="section container detail-layout">
    <article class="detail-main">
      <img
        src="<%= item.image %>"
        alt="<%= item.title %> di Berastagi"
        class="detail-cover"
        loading="lazy"
      />

      <span class="eyebrow">Wisata Berastagi</span>
      <h1><%= item.title %></h1>

      <div class="detail-meta">
        <span>Lokasi: <%= item.location %></span>
        <span>Jam buka: <%= item.open_hours || '-' %></span>
        <span>Tiket: <%= helpers.formatCurrency(item.ticket_price || 0) %></span>
      </div>

      <div class="detail-content article-content">
        <%
          const rawContent = item.content || "";
          const hasHtmlTags = /<\/?[a-z][\s\S]*>/i.test(rawContent);
        %>

        <% if (hasHtmlTags) { %>
          <%- rawContent %>
        <% } else { %>
          <%- rawContent
            .split(/\n\s*\n/)
            .map(paragraph => `<p>${paragraph.replace(/\n/g, "<br>")}</p>`)
            .join("") %>
        <% } %>
      </div>

      <section class="rating-box" id="rating">
        <h2>Rating Pengunjung</h2>
        <p><strong><%= avg || 0 %>/5</strong> dari <%= ratings.length %> ulasan</p>

        <form action="/wisata/<%= item.slug %>/rating" method="post" class="inline-form">
          <input type="text" name="name" placeholder="Nama kamu" required />
          <select name="rating" required>
            <option value="">Pilih rating</option>
            <option value="5">5 - Sangat bagus</option>
            <option value="4">4 - Bagus</option>
            <option value="3">3 - Cukup</option>
            <option value="2">2 - Kurang</option>
            <option value="1">1 - Buruk</option>
          </select>
          <button type="submit">Kirim Rating</button>
        </form>
      </section>

      <section class="comment-box" id="ulasan">
        <h2>Ulasan dan Komentar Pengunjung</h2>

        <form action="/wisata/<%= item.slug %>/comment" method="post" class="comment-form">
          <input type="text" name="name" placeholder="Nama" required />
          <input type="email" name="email" placeholder="Email (opsional)" />
          <textarea name="comment" rows="5" placeholder="Tulis komentar..." required></textarea>
          <button type="submit">Kirim Komentar</button>
        </form>

        <div class="comment-list">
          <% comments.forEach(comment => { %>
            <article class="comment-item">
              <h3><%= comment.name %></h3>
              <p><%= comment.comment %></p>
              <small><%= comment.created_at %></small>
            </article>
          <% }) %>

          <% if (!comments.length) { %>
            <p>Belum ada komentar yang tampil. Jadilah yang pertama mengirim ulasan untuk tempat wisata ini.</p>
          <% } %>
        </div>
      </section>
    </article>

    <aside class="detail-sidebar">
      <div class="sticky-box">
        <h3>Informasi Singkat</h3>
        <ul class="info-list">
          <li><strong>Lokasi:</strong> <%= item.location %></li>
          <li><strong>Tiket:</strong> <%= helpers.formatCurrency(item.ticket_price || 0) %></li>
          <li><strong>Jam buka:</strong> <%= item.open_hours || '-' %></li>
        </ul>

        <% if (item.maps_url) { %>
          <a href="<%= item.maps_url %>" target="_blank" rel="noopener" class="btn-primary full">Lihat Maps</a>
        <% } %>
      </div>

      <div class="sticky-box">
        <h3>Wisata Terkait</h3>
        <% related.forEach(rel => { %>
          <a href="/wisata/<%= rel.slug %>" class="mini-link"><%= rel.title %></a>
        <% }) %>
      </div>
    </aside>
  </section>

  <%- include("partials/footer", { settings }) %>
</body>
</html>
