<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>
<body>
  <%- include("partials/header") %>

  <section class="page-hero small">
    <div class="container">
      <span class="eyebrow">Pencarian</span>
      <h1>Hasil Pencarian</h1>
      <p>
        Kata kunci:
        <strong><%= q || "-" %></strong>
      </p>
    </div>
  </section>

  <section class="section container">
    <% if (!q) { %>
      <div class="empty-state reveal">
        <h3>Masukkan kata kunci pencarian</h3>
        <p>
          Cari tempat wisata, villa, kuliner, atau berita terbaru di Berastagi.
        </p>
      </div>
    <% } else { %>
      <div class="search-wrap">
        <div class="search-card reveal">
          <h2>Tempat Wisata</h2>

          <% if (wisata && wisata.length) { %>
            <% wisata.forEach(item => { %>
              <a href="/wisata/<%= item.slug %>" class="mini-link"><%= item.title %></a>
            <% }) %>
          <% } else { %>
            <p>Tidak ada hasil tempat wisata.</p>
          <% } %>
        </div>

        <div class="search-card reveal">
          <h2>Villa &amp; Hotel</h2>

          <% if (villa && villa.length) { %>
            <% villa.forEach(item => { %>
              <a href="/villa/<%= item.slug %>" class="mini-link"><%= item.title %></a>
            <% }) %>
          <% } else { %>
            <p>Tidak ada hasil villa atau hotel.</p>
          <% } %>
        </div>

        <div class="search-card reveal">
          <h2>Kuliner</h2>

          <% if (kuliner && kuliner.length) { %>
            <% kuliner.forEach(item => { %>
              <a href="/kuliner/<%= item.slug %>" class="mini-link"><%= item.title %></a>
            <% }) %>
          <% } else { %>
            <p>Tidak ada hasil kuliner.</p>
          <% } %>
        </div>

        <div class="search-card reveal">
          <h2>Berita</h2>

          <% if (berita && berita.length) { %>
            <% berita.forEach(item => { %>
              <a href="/berita/<%= item.slug %>" class="mini-link"><%= item.title %></a>
            <% }) %>
          <% } else { %>
            <p>Tidak ada hasil berita.</p>
          <% } %>
        </div>
      </div>
    <% } %>
  </section>

  <%- include("partials/footer", { settings }) %>
</body>
</html>
